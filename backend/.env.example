# ============================================
# Resend Configuration
# ============================================

# Resend API Key (create one at https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key_here

# Verified sender email address in Resend
# IMPORTANT: This email domain must be verified in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Optional: Fallback sender email
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# Other Environment Variables
# ============================================

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# Backend URL
BACKEND_URL=http://localhost:5000

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/vidfly

# Server Port
PORT=5000

# ============================================
# Cashfree Configuration (Payment Gateway)
# ============================================

# Environment: TEST or PRODUCTION
CASHFREE_ENVIRONMENT=TEST

# Production Credentials (from Cashfree Dashboard -> Payment Gateway -> Credentials)
CASHFREE_CLIENT_ID=your_cashfree_app_id
CASHFREE_CLIENT_SECRET=your_cashfree_secret_key

# Webhook Secret (from Cashfree Dashboard -> Webhooks)
CASHFREE_WEBHOOK_SECRET=your_webhook_secret

# Origin URLs (no trailing slash)
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:5000

# ============================================
# Auth Cookie Configuration
# ============================================
# For same-site localhost development (frontend + backend on localhost), defaults are fine.
# For cross-site local testing (frontend on localhost, backend on vidflyy.com), set:
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_DOMAIN=.vidflyy.com
#
# Allowed AUTH_COOKIE_SAME_SITE values: lax | strict | none
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# ============================================
# NOTES FOR RESEND SETUP
# ============================================
# 
# 1. Create a Resend Account:
#    - Sign up at https://resend.com/
#    - Free tier includes 3,000 emails/month (100/day)
#
# 2. Create an API Key:
#    - Go to API Keys section
#    - Create a new key (name it e.g., "vidflyy-production")
#    - Copy the key immediately (starts with "re_")
#
# 3. Verify Your Domain:
#    - Go to Domains section
#    - Add your domain (e.g., vidflyy.com)
#    - Add the DNS records Resend provides
#    - Wait for verification (usually quick)
#
# 4. Without Resend API Key:
#    - Emails will be logged to console only (dev mode)
#    - No actual emails will be sent
#

# ============================================
# Resend Configuration
# ============================================

# Resend API Key (create one at https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key_here

# Verified sender email address in Resend
# IMPORTANT: This email domain must be verified in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Optional: Fallback sender email
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# Other Environment Variables
# ============================================

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# Backend URL
BACKEND_URL=http://localhost:5000

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/vidfly

# Server Port
PORT=5000

# ============================================
# NOTES FOR RESEND SETUP
# ============================================
# 
# 1. Create a Resend Account:
#    - Sign up at https://resend.com/
#    - Free tier includes 3,000 emails/month (100/day)
#
# 2. Create an API Key:
#    - Go to API Keys section
#    - Create a new key (name it e.g., "vidflyy-production")
#    - Copy the key immediately (starts with "re_")
#
# 3. Verify Your Domain:
#    - Go to Domains section
#    - Add your domain (e.g., vidflyy.in)
#    - Add the DNS records Resend provides
#    - Wait for verification (usually quick)
#
# 4. Without Resend API Key:
#    - Emails will be logged to console only (dev mode)
#    - No actual emails will be sent
#

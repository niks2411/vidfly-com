# ============================================
# AWS SES Configuration (Production & Local Testing)
# ============================================

# AWS Region where SES is configured (e.g., us-east-1, ap-south-1, eu-west-1)
AWS_REGION=us-east-1

# AWS IAM Credentials (create an IAM user with SES sending permissions)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Verified sender email address in AWS SES
# IMPORTANT: This email must be verified in AWS SES console
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Optional: Fallback sender email (if not set, uses AWS_SES_FROM_EMAIL)
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# Other Environment Variables
# ============================================

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Email Cookie Secret
EMAIL_COOKIE_SECRET=your_email_cookie_secret_here

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/vidfly

# Server Port
PORT=5000

# ============================================
# NOTES FOR LOCAL TESTING WITH AWS SES
# ============================================
# 
# 1. AWS SES starts in SANDBOX mode:
#    - You can only send emails to verified email addresses
#    - Verify recipient emails in AWS SES Console > Verified Identities
#    - Daily sending limit: 200 emails, max 1 email/second
#
# 2. For Production (after requesting production access):
#    - Can send to any email address
#    - Higher sending limits (50,000 emails/day by default)
#
# 3. Without AWS credentials:
#    - Emails will be logged to console only (dev mode)
#    - No actual emails will be sent
#
